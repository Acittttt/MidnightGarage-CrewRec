# ================================================================
# Midnight Garage — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ================================================================

# --- Server ---
PORT=3000
ALLOWED_ORIGIN=http://localhost:3000

# --- Database (GCP Cloud SQL — MySQL) ---
DB_HOST=YOUR_CLOUD_SQL_PUBLIC_IP_OR_SOCKET
DB_USER=YOUR_DB_USERNAME
DB_PASS=YOUR_DB_PASSWORD
DB_NAME=midnight_garage
DB_PORT=3306
# Set to "true" when connecting to Cloud SQL over public IP
DB_SSL=false

# --- Google Cloud Storage ---
GCS_BUCKET_NAME=YOUR_GCS_BUCKET_NAME
GCP_PROJECT_ID=YOUR_GCP_PROJECT_ID

# --- Service Account (local dev only)
# When deployed to Cloud Run/App Engine, ADC is used automatically.
# Point this to your downloaded service account JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json
